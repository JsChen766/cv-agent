# Docker 部署环境变量
# 复制此文件为 .env.docker，填入真实值，不要提交到 Git

# ── 数据库 ────────────────────────────────────────────────────────────────────
# 注意：host 是 postgres（docker-compose service 名），不是 localhost
DATABASE_URL=postgresql+asyncpg://cvbe:cvbe@postgres:5432/cvbe

# ── 安全 ──────────────────────────────────────────────────────────────────────
# 生产环境必须替换：openssl rand -hex 32
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32

# ── LLM 配置 ──────────────────────────────────────────────────────────────────
# openai | anthropic
LLM_PROVIDER=openai
LLM_MODEL=deepseek-v4-flash
LLM_API_KEY=sk-...
# 非 OpenAI 官方接口时填写（如 Azure、DeepSeek、Qwen）
LLM_BASE_URL=https://api.deepseek.com

# ── Embedding ─────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
# 使用独立 OpenAI-compatible embedding 服务时填写
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_DIMENSIONS=512
EMBEDDING_LOCAL_FILES_ONLY=true
EMBEDDING_PROVIDER=local

# ── 应用 ──────────────────────────────────────────────────────────────────────
ENVIRONMENT=production
