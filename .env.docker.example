NODE_ENV=development
HOST=0.0.0.0
PORT=3000
DATABASE_URL=postgres://coolto:coolto_dev_password@postgres:5432/coolto_agent
AUTH_MODE=dev_header
ALLOW_DEV_HEADER_AUTH=true
ALLOW_INSECURE_AUTH=true
# AUTH_MODE=dev_header requires request header: x-user-id: dev-user
FILE_STORAGE_PROVIDER=local
FILE_STORAGE_DIR=.data/uploads
EXPORT_STORAGE_DIR=.data/exports
PDF_RENDERER=none
DEBUG_ROUTES_ENABLED=true
RATE_LIMIT_ENABLED=false
AGENT_MODEL_PROVIDER=deepseek
# Legacy aliases are also supported in runtime code:
AGENT_PROVIDER=deepseek
AGENT_MODEL=deepseek-chat
AGENT_API_KEY=
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=
DEEPSEEK_MODEL=deepseek-chat
