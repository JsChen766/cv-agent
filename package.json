{
  "name": "coolto-agent-runtime",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Extensible TypeScript multi-agent runtime foundation for Coolto.",
  "scripts": {
    "dev:single": "tsx src/examples/single-agent-demo.ts",
    "dev:multi": "tsx src/examples/multi-agent-demo.ts",
    "dev:tool": "tsx src/examples/tool-call-demo.ts",
    "dev:agent-tool-runner": "tsx src/examples/agent-tool-runner-demo.ts",
    "dev:conversation-runtime": "tsx src/examples/conversation-runtime-demo.ts",
    "dev:memory": "tsx src/examples/memory-demo.ts",
    "dev:knowledge": "tsx src/examples/knowledge-demo.ts",
    "dev:knowledge-pipeline": "tsx src/examples/knowledge-pipeline-demo.ts",
    "dev:coolto-demo": "tsx src/examples/coolto-demo-service-demo.ts",
    "dev:agent-ingest": "tsx src/examples/agent-ingest-demo.ts",
    "dev:agent-coolto": "tsx src/examples/agent-coolto-demo.ts",
    "dev:agent-kernel": "tsx src/examples/agent-kernel-demo.ts",
    "dev:postgres-kernel": "tsx src/examples/postgres-kernel-demo.ts",
    "dev:generation-session": "tsx src/examples/generation-session-demo.ts",
    "dev:generation-session-forced-gap": "tsx src/examples/generation-session-forced-gap-demo.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "pg": "^8.20.0",
    "sql.js": "^1.14.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^20.17.10",
    "@types/pg": "^8.20.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
